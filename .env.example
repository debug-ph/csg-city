# Starkes, zufälliges Secret für Sessions (min. 32 Zeichen)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=dein-zufaelliges-secret-hier

# TOTP-Secret für den Admin-Login (Base32, bereits im Authenticator registriert)
TOTP_SECRET=ND7NTFOAVACPAYSM4EW33HFJHRQBI2PH

# Produktionsmodus aktiviert sichere Cookies (HTTPS erforderlich)
# NODE_ENV=production
